    "firebase": "^10.12.2",
    "joi": "^18.0.1",
    "mariadb": "^3.3.2",
    "mysql2": "^3.11.3",
    "sequelize": "^6.37.3",
    "serverless-http": "^3.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
